{
    "name": "mmo-platform/admanager",
    "description": "Multi-project ad platform for Google Ads and Meta campaigns",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "googleads/google-ads-php": "^29.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AdManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdManager\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}
