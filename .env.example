# Google Ads API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# YouTube Data API (reuses Google OAuth client ID/secret above)
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Meta (Facebook/Instagram) Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXX
META_PIXEL_ID=
# META_API_VERSION=v20.0
# META_TEST_EVENT_CODE=TEST12345  # Set during CAPI testing in Events Manager

# Creative generation
OPENROUTER_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
FFMPEG_PATH=/usr/bin/ffmpeg

# Google Analytics 4 (optional — for landing page analysis + conversion validation)
GA4_PROPERTY_ID=

# Database (optional — defaults to db/admanager.db)
# ADMANAGER_DB_PATH=

# Brand / project defaults
BRAND_URL=https://example.com

# Dashboard auth (bcrypt hash — omit to disable auth in dev mode)
# Generate: php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT) . PHP_EOL;"
# ADMIN_PASSWORD_HASH=$2y$10$...
